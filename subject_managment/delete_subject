 delete_subject(){
   echo "Enter s subject to be deleted" 
   read code
   
   if ! [[ $code =~ ^[A-Za-z0-9]+$ ]]; then
   	echo "not valid subject code" 
   	return
   fi
     grade_file="../grade_managment/grades/$code.grd"
     sub_file="../subject_managment/subjects/$code.sub"
   if [[ ! -f $sub_file ]]; then 
   	echo "no such subject added"
   		return
   fi
 while true; do
    echo "you really want to delete $code ? (Y/N)"
    read cho

    if [[ $cho == "Y" || $cho == "y" ]]; then
        rm -f "$sub_file"
        rm -f "$grade_file"
        echo "deleted successfully"
        break

    elif [[ $cho == "N" || $cho == "n" ]]; then
        echo "cancelled"
        break

    else
        echo "invalid choice"
    fi
done
    
   
   
   
}
