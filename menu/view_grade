function view_grade(){

file="../sgms_data/grades"
if [[ -z "$(ls -A "$file")" ]]; then
echo "no data found"
return
fi
echo "Enter subject code" 
read code
 filegrd="../sgms_data/grades/$code.grd"
 filesub="../sgms_data/subjects/$code.sub"
if [[ ! -f $filesub ]]; then
    echo "Subject not found!"
    return
fi

if [[ ! -f $filegrd ]]; then
echo "no grades found"
  return
  fi
  echo "StudentID | Score | Grade"
  echo "--------------------------"
  cat "$filegrd"
}




 
