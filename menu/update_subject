 update_subject(){
echo "CODE=$code"
echo "FILE=$file_update"
ls ../sgms_data/subjects
  echo "enter a subject code" 
  read code
  
 file_update="../sgms_data/subjects/$code.sub"
  
   if ! [ -f "$file_update" ]; then
        echo "file not founded"
         return
   
        
    fi   
     
  echo "Enter a new name" 
  read name
    if [[ ! $name =~ ^[A-Za-z[:space:]]+$ ]]; then
        echo "Invalid name!"
        return
    fi
  echo "Enter a new credit" 
  read credit
  
   if ! [[ $credit =~ ^[1-6]$ ]]; then
        echo "Invalid Credit!"
        return
    fi
  
  
  echo "$code">>"$file_update"
  echo "$name">>"$file_update"
  echo "$credit">>"$file_update"
  
    
  echo "update sucssessfully"






























}
