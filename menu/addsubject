 
 add_subject(){
  mkdir -p ../sgms_data/subjects

while true;do
echo "Enter subject code" 
read code
if ! [[ $code =~ ^[A-Za-z]{2,5}[1-9]{2,5}$ ]]; then

   echo "this is not a valid code"
else
 break
 fi
 done

  
 while true ;do
echo "Enter subject name" 
read name
if ! [[ $name =~ ^[A-Za-z[:space:]]+$ ]]; then

   echo "this is not a valid name"
else
break
fi
done



while true ;do
echo "Enter subject credit" 
read credit
if ! [[ $credit =~ ^[1-6]$ ]]; then

   echo "this is not a valid credit"
else
break
fi 
done


file_sub="../sgms_data/subjects/$code.sub"

if [[ -f $file_sub ]]; then
echo "file exist alredy"
return
fi

echo "$code" >> "$file_sub"
echo "$name" >> "$file_sub"
echo "$credit" >> "$file_sub"
echo "subject added successfully"
} 
